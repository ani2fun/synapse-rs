---
// The site header: brand link home, the `.header__search` button that islands/palette.ts
// hydrates into the ⌘K command palette (also the e2e selector `reader.spec.ts` clicks), the
// Blog link (glyph + label; the glyph stands down on a phone, where the row has no spare
// width), the light/dark theme toggle (islands/theme.ts flips `.dark` on <html>), and the
// account chip mount host.
---

<header class="header">
  <nav class="header__nav">
    <a class="header__brand" href="/">
      <svg class="header__chip" width="30" height="30" viewBox="0 0 30 30" aria-hidden="true">
        <rect width="30" height="30" rx="7" fill="hsl(var(--primary))"></rect>
        <g stroke="hsl(var(--primary-foreground))" stroke-width="1.6">
          <line x1="10" y1="19" x2="15" y2="10"></line>
          <line x1="15" y1="10" x2="20" y2="19"></line>
          <line x1="10" y1="19" x2="20" y2="19"></line>
        </g>
        <g fill="hsl(var(--primary-foreground))">
          <circle cx="15" cy="10" r="2.4"></circle>
          <circle cx="10" cy="19" r="2.4"></circle>
          <circle cx="20" cy="19" r="2.4"></circle>
        </g>
      </svg>
      <span class="header__wordmark">synapse</span>
    </a>
    <div class="header__mid">
      <button class="header__search" type="button" title="Search the library (⌘K)" aria-label="Search the library">
        <svg
          class="header__search-ic"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <span class="header__search-text">Search the library…</span>
        <kbd class="header__search-kbd">⌘K</kbd>
      </button>
    </div>
    <div class="header__actions">
      <a class="header__link" href="/blog">
        <svg
          class="header__link-ic"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z"
          ></path>
        </svg>
        <span>Blog</span>
      </a>
      <!-- Light/dark toggle. Both glyphs render; CSS shows the one you'd switch TO (moon in light,
           sun in dark). islands/theme.ts (global) wires the click + persists the choice. -->
      <button class="header__icon-btn" type="button" data-theme-toggle aria-label="Switch to dark theme" title="Toggle theme">
        <svg class="header__icon-btn__moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
        <svg class="header__icon-btn__sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2 M12 20v2 M4.9 4.9l1.4 1.4 M17.7 17.7l1.4 1.4 M2 12h2 M20 12h2 M4.9 19.1l1.4-1.4 M17.7 6.3l1.4-1.4"></path>
        </svg>
      </button>
      <!-- The account chip's mount host. islands/auth (loaded globally from Base) renders the
           Preact `Chip` in here, after the Blog link; its own root carries `account-chip`. -->
      <span data-account-chip></span>
    </div>
  </nav>
</header>
