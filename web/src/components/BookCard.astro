---
// One library card. `data-book-slug` is what islands/library.ts uses to find this card again
// after hydration — book slugs are globally unique (tree.ts's `findBook` test), so a single
// attribute is enough to re-resolve the book without re-walking the whole catalog tree per card.
//
// The progress bar is deliberately ABSENT from this markup: it is injected client-side into the
// footer by islands/library.ts once localStorage resolves. SSR has no reading history to show —
// "nothing until there is something to report" rule, run after hydration rather than inline here.
import { chapterCount, firstLessonPath, lessonCount } from "../lib/catalog/tree";
import type { components } from "../lib/api/schema.gen";

type Book = components["schemas"]["BookDto"];

interface Props {
  book: Book;
}

const { book } = Astro.props;

function plural(n: number, word: string): string {
  return n === 1 ? word : `${word}s`;
}

const chapters = chapterCount(book);
const lessons = lessonCount(book);
const metaParts: string[] = [];
if (chapters > 0) metaParts.push(`${chapters} ${plural(chapters, "chapter")}`);
metaParts.push(`${lessons} ${plural(lessons, "lesson")}`);
if (book.estimatedReadingMinutes != null) metaParts.push(`~${book.estimatedReadingMinutes} min`);
const meta = metaParts.join(" · ");
const tags = book.tags.slice(0, 3);
const primaryTag = tags.length > 0 ? tags[0] : null;
const path = firstLessonPath(book);
---

{
  path ? (
    <a class="lib-card" href={`/synapse/${path}`} data-book-slug={book.slug}>
      <div class="lib-card__top">
        <span class="lib-card__tile" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v18H6.5A2.5 2.5 0 0 0 4 22.5z" />
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
          </svg>
        </span>
        {primaryTag && <span class="lib-card__badge">{primaryTag}</span>}
      </div>
      <div class="lib-card__title">{book.title}</div>
      {book.description && <p class="lib-card__desc">{book.description}</p>}
      <div class="lib-card__meta">
        <svg
          class="lib-card__meta-ic"
          viewBox="0 0 24 24"
          width="14"
          height="14"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
        </svg>
        <span>{meta}</span>
      </div>
      <div class="lib-card__footer">
        <span class="lib-card__cta">
          Read
          <svg
            class="lib-card__cta-ic"
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14 M13 6l6 6-6 6" />
          </svg>
        </span>
      </div>
    </a>
  ) : (
    <div class="lib-card lib-card--empty" data-book-slug={book.slug}>
      <div class="lib-card__top">
        <span class="lib-card__tile" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v18H6.5A2.5 2.5 0 0 0 4 22.5z" />
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
          </svg>
        </span>
        {primaryTag && <span class="lib-card__badge">{primaryTag}</span>}
      </div>
      <div class="lib-card__title">{book.title}</div>
      {book.description && <p class="lib-card__desc">{book.description}</p>}
      <div class="lib-card__meta">
        <svg
          class="lib-card__meta-ic"
          viewBox="0 0 24 24"
          width="14"
          height="14"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
        </svg>
        <span>{meta}</span>
      </div>
      <div class="lib-card__footer">
        <span class="lib-card__cta">
          Read
          <svg
            class="lib-card__cta-ic"
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14 M13 6l6 6-6 6" />
          </svg>
        </span>
      </div>
    </div>
  )
}
