---
// The document frame every page shares. The head is NATIVE here — no server-side string
// surgery: the per-page title/description/canonical/OG machinery is ordinary props.
//
// The stylesheets are imported from web/styles/ — zero framework selectors in them
// (verified by inventory), single-sourced from there rather than duplicated here.
import "../../styles/tokens.css";
import "../../styles/shell.css";
// The ⌘K palette's classes — global chrome, mounted on every page (see the palette island
// import below), so its stylesheet belongs in the shared layout rather than any one page.
// Without this the `.cmdk-scrim` fixed-centering rule never applies and the palette renders in
// normal flow instead of as a centered overlay.
import "../../styles/search.css";
// The account chip's classes live in reader.css (`.account-chip*`), and the chip renders in the
// GLOBAL header — so its stylesheet belongs here rather than only on lesson pages (which also
// import it; Vite dedupes). Every reader.css selector is scoped (`html[data-reader-*]`, `.reader-*`,
// `.account-chip*`, `.lesson`, `.synapse-prose`), so nothing leaks onto the landing / blog pages.
import "../../styles/reader.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /** Site-relative path for canonical + og:url; omitted = no canonical tag. */
  canonicalPath?: string;
  /** Landing page ONLY: lesson pages own their vertical rhythm, and problem pages are a
   *  fixed-height two-pane layout with no page scroll at all — a footer there is unreachable or
   *  fights the panes. Rendering it everywhere surfaced as broken pane scrolling on problem
   *  pages. */
  footer?: boolean;
}

const SITE_NAME = "Synapse";
const DEFAULT_DESCRIPTION =
  "Read, run and understand — interactive lessons on system design, data structures and " +
  "algorithms, with code you can execute and visualise in the page.";

const { title = SITE_NAME, description = DEFAULT_DESCRIPTION, canonicalPath, footer = false } = Astro.props;
// Absolute origin for OG/canonical — configured, never sniffed from Host (caller-controlled),
// same rule as the axum side.
const siteUrl = (import.meta.env.SYNAPSE_SITE_URL ?? "https://synapse.kakde.eu").replace(/\/+$/, "");
const canonical = canonicalPath ? `${siteUrl}${canonicalPath}` : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <!-- The theme bootstrap: .dark on <html> BEFORE first paint — stored choice wins, else the
         OS preference. The CSP allows this inline script by design. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          var dark = t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", dark);
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <slot />
    {footer && <Footer />}
    <!-- The ⌘K palette: mounted from Base so it exists on EVERY page — the e2e palette spec
         opens it from `/`, and this island wires up the header's `.header__search` button.
         Vanilla TS, lazy data load on first open (islands/palette.ts). -->
    <script>
      import "../islands/palette";
    </script>
    <!-- The auth boot island: loaded on EVERY page because the header (and its account chip) is
         global — check-sso runs everywhere, the chip mounts, and the bearer/`__synapseAuth`/
         `__synapseVizToken` seams + the AUTH_CHANGED event install before any workbench renders.
         keycloak-js stays a lazy chunk (the loader dynamic-imports it). -->
    <script>
      import "../islands/auth";
    </script>
    <!-- The header's light/dark toggle: flips `.dark` on <html> and persists the choice. Global,
         like the palette and auth islands, so the control works on every page. -->
    <script>
      import "../islands/theme";
    </script>
  </body>
</html>
