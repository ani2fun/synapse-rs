---
// The lesson page. `/synapse/{...path}` server-renders a real lesson through the EXACT markdown
// pipeline the reader uses (`renderLesson`, web/src/lib/markdown), with a native per-page head.
// This is what turns the hydrate-first reader's ~7.2s-on-a-phone first paint into ~1.3s: the
// prose is HTML in the response, not something a multi-megabyte wasm bundle produces after it
// boots.
//
// A `kind: problem` lesson server-renders the two-pane workbench frame (crumbs · left pane with
// the DESCRIPTION markdown + tab bar · a right-pane placeholder · the docked nav bar) instead of
// the prose fallback. `islands/problem` extracts the first workbench into the right pane and
// wires the tabs/splitter/submissions over the static frame.
//
// Head PARITY with the axum side (server/src/platform/static_routes.rs::render_head, which the
// e2e `per-page head` spec asserts on the raw response): title = `Book · Lesson — Synapse`,
// description = the lesson summary (else Base's default, byte-identical to the server's), a
// canonical `/synapse/{path}`, and the Open Graph tags Base already emits.
//
// The Editorial tab has its own stepper island; the lesson body hydrates quiz/diagram/
// LikeC4-embed placeholders (`islands/widgets`), the docked problem page's 4th tab is Coach
// (`islands/coach/CoachPane`), and fence bars carry the codebench modal ("Try in Editor"). The
// sidebar is structure only here — its interactive faces live in `islands/chrome.ts`.
import Base from "../../layouts/Base.astro";
import Sidebar from "../../components/Sidebar.astro";
import Pager from "../../components/Pager.astro";
import NotFound from "../../components/NotFound.astro";
import { lesson as fetchLesson, fetchIndex, ApiFailure } from "../../lib/api/client";
import type { LessonPayload } from "../../lib/api/client";
import { renderLesson } from "../../lib/markdown/render";
import * as log from "../../lib/log";
import { titleForLesson, SITE_NAME } from "../../lib/seo";
import { allBooksOf, bookOf, chapterProblems, chapterTitleOf, problemContentSplit } from "../../lib/catalog/tree";
import { DEFAULT_LEFT_PCT } from "../../lib/catalog/pane";
import type { components } from "../../lib/api/schema.gen";

import "../../../styles/reader.css";
import "../../../styles/runnable.css";
// viz.css carries MORE than the viz widgets: the workbench's language dropdown
// (`.wb__lang-menu`/`-scrim`/`-opt`) lives there too — without it the menu renders as bare
// stacked buttons.
import "../../../styles/viz.css";
import "../../../styles/markdown.css";
import "../../../styles/practice.css";
import "../../../styles/diagrams.css";
import "../../../styles/coach.css";
import "../../../styles/codebench.css";

type Mode = "lesson" | "problem" | "notFound" | "error";

/** `count-all-digits` → `Count All Digits`. */
function humanize(slug: string): string {
  return slug
    .split("-")
    .map((w) => (w === "" ? "" : w[0].toUpperCase() + w.slice(1)))
    .join(" ");
}

const rawPath = Astro.params.path ?? "";
const segments = rawPath.split("/").filter((segment) => segment !== "");

const ssrStart = Date.now();
let mode: Mode = "error";
let payload: LessonPayload | null = null;
let html = "";
let descriptionHtml = "";
// The RAW editorial markdown (inline tail, else the sidecar) — the stepper island parses it and
// renders per-section on first open of the Editorial tab, so the server ships the markdown, not
// pre-rendered HTML.
let editorialMd = "";
let counter: { problems: string[]; at: number } | null = null;
let book: components["schemas"]["BookDto"] | null = null;
// Every book in the catalog — the sidebar's "Back to Main" browse list (the design's two-mode
// left rail: the current book's contents ⇄ all books). Empty if the index can't load.
let allBooks: components["schemas"]["BookDto"][] = [];
let errorMessage = "";

try {
  payload = await fetchLesson(segments);
  mode = payload.frontmatter.kind === "problem" ? "problem" : "lesson";
  if (mode === "problem") {
    // The FIRST `<details` at line start outside a fence splits description from editorial; the
    // inline editorial wins, else the co-located sidecar the payload already carries.
    const [descMd, inlineEditorial] = problemContentSplit(payload.raw);
    descriptionHtml = await renderLesson(descMd);
    editorialMd = inlineEditorial.trim() !== "" ? inlineEditorial : (payload.editorial ?? "");
  } else {
    html = await renderLesson(payload.raw);
  }
  // The sidebar needs the FULL book tree (payload.book is only a ref). Best-effort: if the index
  // can't load, the sidebar degrades to absent rather than failing the whole page. The
  // problem-page counter rides the same book.
  try {
    const index = await fetchIndex();
    book = bookOf(index, segments);
    allBooks = allBooksOf(index);
    if (mode === "problem" && book) counter = chapterProblems(book, segments.join("/"));
  } catch {
    book = null;
  }
} catch (error) {
  if (error instanceof ApiFailure && error.status === 404) {
    mode = "notFound";
    Astro.response.status = 404;
  } else {
    mode = "error";
    Astro.response.status = 502;
    errorMessage = error instanceof Error ? error.message : String(error);
  }
}

const isLesson = mode === "lesson" || mode === "problem";
const canonicalPath = `/synapse/${segments.join("/")}`;
log.info(
  `SSR /synapse/${segments.join("/")} — ${mode}${isLesson ? "" : ` (${errorMessage ?? "not found"})`} in ${Date.now() - ssrStart}ms`,
);
const title =
  payload && isLesson
    ? titleForLesson(payload.book.title, payload.frontmatter.title)
    : mode === "notFound"
      ? `Not found — ${SITE_NAME}`
      : `Error — ${SITE_NAME}`;
// `?? undefined` (never null) so Base falls back to its default description — the same string the
// axum side uses when a lesson has no summary, keeping the two heads in agreement.
const description = payload?.frontmatter.summary ?? undefined;

const bookName = payload ? humanize(payload.book.slug) : "";
const difficulty = payload?.frontmatter.difficulty ?? null;
// The reader eyebrow: the chapter this lesson sits in, else the book title. The right rail's
// "Up next" reuses payload.next (the same neighbour the pager already renders).
const eyebrow = book ? (chapterTitleOf(book, segments.join("/")) ?? book.title) : null;
// The Suggest-an-edit tooltip in its GATED state — what a reader who is not (yet) a content
// editor sees on hover. Server-rendered as the default so the affordance is honest before any JS
// runs: the feature exists, here is how to ask for it. islands/authoring/editLink swaps in the
// active copy once the server confirms the caller may edit.
const EDIT_GATED_TIP =
  "Editing needs a place on the content-editor list. To request one, email your GitHub username to a.r.kakde@gmail.com — access may or may not be granted. Thanks for understanding.";
---

<Base title={title} description={description} canonicalPath={isLesson ? canonicalPath : undefined}>
  {mode === "notFound" && <NotFound path={rawPath} />}

  {
    mode === "error" && (
      <main class="shell-main">
        <section class="lesson lesson--error">
          <h1 class="reader-prose__title">Something went wrong</h1>
          <p class="reader-prose__lede">{errorMessage}</p>
          <p>
            <a class="header__link" href="/">
              ← Back to the library
            </a>
          </p>
        </section>
      </main>
    )
  }

  {
    mode === "lesson" && payload && (
      <main class="shell-main">
        <div class="reader-layout" data-sidebar="expanded">
          <aside class="reader-sidebar">{book && <Sidebar book={book} books={allBooks} currentPath={segments.join("/")} />}</aside>
          <article class="reader-layout__main">
            <div class="lesson">
              <header class="lesson-header">
                {eyebrow && <p class="reader-prose__eyebrow">{eyebrow}</p>}
                <h1 class="reader-prose__title">{payload.frontmatter.title}</h1>
                {payload.frontmatter.summary && <p class="reader-prose__lede">{payload.frontmatter.summary}</p>}
                <!-- Always VISIBLE, gated by default — the problem workbench's Submit button
                     grammar: a reader who cannot use it still sees it exists and, on hover, how to
                     ask for access, rather than an affordance that silently is not there.
                     islands/authoring/editLink upgrades it to a live link when the server says the
                     caller may edit, and removes it entirely when editing is switched off. The
                     tooltip is `.wb__tip[data-tip]` (runnable.css) rather than a native `title`:
                     that is too slow and is suppressed on disabled controls. An HTML comment (not a
                     JSX one): dev-mode script extraction can choke on JSX comments, the same class
                     of scar as the apostrophe note below. -->
                <span class="wb__tip lesson-edit-tip" data-edit-tip data-tip={EDIT_GATED_TIP}>
                  <a
                    class="lesson-edit-link lesson-edit-link--gated"
                    href={`/edit/${segments.join("/")}`}
                    data-edit-link
                    aria-disabled="true"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 20h9 M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
                    </svg>
                    Suggest an edit
                  </a>
                </span>
              </header>

              <article class="lesson-body synapse-prose" set:html={html} />

              <nav class="reader-pager">
                <Pager target={payload.prev} label="Previous" next={false} />
                <Pager target={payload.next} label="Next" next={true} />
              </nav>
            </div>
          </article>

          <aside class="reader-aside" aria-label="Reading aside">
            <div class="reader-aside__card">
              <span class="reader-aside__eyebrow">Your progress</span>
              <div class="reader-aside__prog-top">
                <span class="reader-aside__pct" data-progress-pct>0%</span>
                <span class="reader-aside__prog-sub" data-progress-sub />
              </div>
              <div class="reader-bar"><div class="reader-bar__fill" data-progress-fill /></div>
            </div>

            {/* chrome.ts renders the "On this page" outline into here on desktop; on smaller
                widths the rail is hidden and the TOC lives in the bottom-right sheet instead. */}
            <nav class="reader-outline" aria-label="On this page" />

            {payload.next && (
              <a class="reader-aside__next" href={`/synapse/${payload.next}`}>
                <span class="reader-aside__eyebrow">Up next</span>
                <span class="reader-aside__next-title">{humanize(payload.next.split("/").pop() ?? payload.next)}</span>
                <span class="reader-aside__next-go">
                  Continue
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
              </a>
            )}
          </aside>
        </div>
        <!-- OUTSIDE the reader grid on purpose: a sibling of `.reader-layout`, never its third
             grid child, or it becomes a phantom grid item at desktop width. The FAB itself is
             CSS-hidden at >=1024px (reader.css's `.reader-nav-fab` media rule); the drawer it
             opens clones `.reader-sidebar .reader-sidebar__inner` at click time
             (islands/reader.ts). -->
        <div class="reader-nav">
          <button class="reader-nav-fab" aria-label="Contents" aria-expanded="false" type="button">
            <svg
              class="reader-nav-fab__ic"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="18" height="18" x="3" y="3" rx="2" />
              <path d="M9 3v18 M14 9l3 3-3 3" />
            </svg>
          </button>
        </div>
      </main>
    )
  }

  {
    mode === "problem" && payload && (
      <main class="shell-main">
        {/* data-sample-tests carries the SAMPLE testcases (server-filtered from the tests.json
            sidecar; hidden judge cases never ship). The description markdown no longer holds a
            testcases fence, so islands/problem reads the workbench suite from here. Empty when
            a lesson has none. (Keep this comment apostrophe-free: an apostrophe inside a JSX
            expression comment breaks the dev-mode script extraction.) */}
        <div class="pwb not-prose" data-problem data-sample-tests={payload.tests ? encodeURIComponent(JSON.stringify(payload.tests)) : ""}>
          <nav class="pwb__crumbs" aria-label="Breadcrumb">
            <a class="pwb__crumb" href="/">
              Home
            </a>
            <span class="pwb__crumb-sep">›</span>
            <span class="pwb__crumb">{bookName}</span>
            <span class="pwb__crumb-sep">›</span>
            <span class="pwb__crumb pwb__crumb--current">{payload.frontmatter.title}</span>
          </nav>

          <div class="pwb__panes">
            <div class="pwb__left" style={`width: ${DEFAULT_LEFT_PCT}%`}>
              <div class="pwb__head">
                <h1 class="pwb__title">{payload.frontmatter.title}</h1>
                {payload.frontmatter.summary && <p class="pwb__lede">{payload.frontmatter.summary}</p>}
              </div>

              <div class="problem-tabs">
                <button class="problem-tab problem-tab--description problem-tab--active" data-tab="description" type="button">
                  <svg class="problem-tab__ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z" />
                    <path d="M14 2v5h5 M16 13H8 M16 17H8 M10 9H8" />
                  </svg>
                  Description
                </button>
                <button class="problem-tab problem-tab--editorial" data-tab="editorial" type="button">
                  <svg class="problem-tab__ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 7v14 M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4" />
                    <path d="M21 18a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1h-5a4 4 0 0 0-4 4" />
                  </svg>
                  Editorial
                </button>
                <button class="problem-tab problem-tab--coach" data-tab="coach" type="button">
                  <svg class="problem-tab__ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 10v6 M2 10l10-5 10 5-10 5z" />
                    <path d="M6 12v5c3 3 9 3 12 0v-5" />
                  </svg>
                  Coach
                </button>
                <button class="problem-tab problem-tab--submissions" data-tab="submissions" type="button">
                  <svg class="problem-tab__ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 3v5h5" />
                    <path d="M3.05 13A9 9 0 1 0 6 5.3L3 8 M12 7v5l4 2" />
                  </svg>
                  Submissions
                </button>
                {difficulty && <span class={`problem-diff problem-diff--${difficulty}`}>{difficulty}</span>}
              </div>

              <div class="pwb__pane-host">
                <div class="pwb__pane" data-pane="description">
                  <div class="pwb__pane-scroll synapse-prose">
                    <div class="pwb-description" set:html={descriptionHtml} />
                  </div>
                </div>
                <div class="pwb__pane hidden" data-pane="editorial">
                  {/* No `.pwb__pane-scroll` wrapper here (unlike the other panes): the stepper
                      island renders its OWN `.pwb-epane > .pwb__pane-scroll` into this host on first
                      open, carrying the raw editorial markdown it parses. */}
                  <div class="pwb-editorial-host" data-editorial={editorialMd ? encodeURIComponent(editorialMd) : ""} />
                </div>
                <div class="pwb__pane hidden" data-pane="coach">
                  <div class="pwb__pane-scroll synapse-prose">
                    <div class="pwb-coach-host" />
                  </div>
                </div>
                <div class="pwb__pane hidden" data-pane="submissions">
                  <div class="pwb__pane-scroll synapse-prose">
                    <div class="psub-host" />
                  </div>
                </div>
              </div>
            </div>

            <div class="wb-split" aria-label="Resize the panes">
              <div class="wb-split__grip">
                <span />
                <span />
                <span />
              </div>
            </div>

            <div class="pwb__right">
              <div class="pwb__nowb">Loading the workbench…</div>
            </div>
          </div>

          <nav class="pwb__nav" aria-label="Problem navigation">
            <div class="pwb__nav-left">
              <button class="pwb__contents" aria-label="Contents — the book's lessons and problems" type="button">
                <svg class="pwb__contents-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="18" height="18" x="3" y="3" rx="2" />
                  <path d="M9 3v18 M14 9l3 3-3 3" />
                </svg>
                <span>Contents</span>
              </button>
            </div>
            <div class="pwb__nav-mid">
              {counter && (
                <>
                  <span class="pwb__nav-count">
                    Problem {counter.at + 1} / {counter.problems.length}
                  </span>
                  <div class="pwb__nav-dots">
                    {counter.problems.map((p, i) => (
                      <a
                        class:list={["pwb__dot", { "pwb__dot--current": i === counter!.at }]}
                        href={`/synapse/${p}`}
                        title={humanize(p.split("/").pop() ?? p)}
                        aria-label={`Problem ${i + 1}`}
                      />
                    ))}
                  </div>
                </>
              )}
            </div>
            <div class="pwb__nav-right">
              {payload.prev && (
                <a class="pwb__step pwb__step--prev" href={`/synapse/${payload.prev}`}>
                  <span class="pwb__step-chev">‹</span>
                  <span class="pwb__step-text">
                    <span class="pwb__step-label">Previous</span>
                    <span class="pwb__step-title">{humanize(payload.prev.split("/").pop() ?? payload.prev)}</span>
                  </span>
                </a>
              )}
              {payload.next && (
                <a class="pwb__step pwb__step--next" href={`/synapse/${payload.next}`}>
                  <span class="pwb__step-text">
                    <span class="pwb__step-label">Next</span>
                    <span class="pwb__step-title">{humanize(payload.next.split("/").pop() ?? payload.next)}</span>
                  </span>
                  <span class="pwb__step-chev">›</span>
                </a>
              )}
            </div>
          </nav>
        </div>

        {/* Hidden source for the Contents drawer: the reader island clones
            `.reader-sidebar .reader-sidebar__inner` on open. The problem page has no visible
            sidebar column (full-width panes), only this clone source. */}
        {book && (
          <div class="pwb-sidebar-src" hidden>
            <aside class="reader-sidebar">
              <Sidebar book={book} books={allBooks} currentPath={segments.join("/")} />
            </aside>
          </div>
        )}
        <!-- The drawer's mount host, PINNED: reader.css hides .reader-nav-scrim/-drawer
             at >=1024px except under .reader-nav--pinned — a body-mounted drawer on this page
             opened into display:none, which is why the Contents pill looked dead on desktop.
             No FAB inside: the crumb-row pill is this page's only trigger (and --pinned hides
             the FAB anyway). -->
        <div class="reader-nav reader-nav--pinned"></div>
      </main>
    )
  }

  {
    /* ONE hoisted script, runtime-branched. Two conditional `<script>` blocks do NOT survive
       Astro's static hoisting — the compiler bundles both and Rollup can hand a page the wrong
       one (a problem page loaded the workbench auto-hydrator, which then double-claimed the first
       workbench). A single block with a `.pwb[data-problem]` runtime check picks the right island
       and keeps each page lean: prose lessons never pull the problem code, and a problem page
       never loads the auto-hydrator that races its extraction. */
    isLesson && payload && (
      <script>
        import "../../islands/reader";
        // The quiz/diagram/c4 pass, guarded the same way workbench/practice are.
        import "../../islands/widgets";
        // The viz loader: no-ops unless the page planted `.viz-widget`s or a workbench
        // variant carries a viz hint — the 280 KiB wasm is fetched lazily, never eagerly.
        import "../../islands/viz";
        if (document.querySelector(".pwb[data-problem]")) {
          import("../../islands/problem");
        } else {
          import("../../islands/workbench");
          // Practice widgets live in ordinary lesson bodies — their `.practice-problem`
          // placeholders auto-hydrate here (the island guards itself off problem pages).
          import("../../islands/practice");
          // The reader chrome (sidebar faces, prefs FAB, TOC + minimap) — lesson pages ONLY, so
          // it rides the dynamic lesson branch, never the problem page.
          import("../../islands/chrome");
          // The Suggest-an-edit affordance: a tiny config probe that un-hides the header link
          // for an allow-listed editor. Prose lessons only (the link is in the lesson header); the
          // problem-page editor surface is out of scope for v1.
          import("../../islands/authoring/editLink");
        }
      </script>
    )
  }
</Base>

<style>
  /* The error block. Everything the problem/lesson pages wear comes from the global
     reader.css / markdown.css / practice.css. */
  .lesson--error {
    max-width: 40rem;
    margin-inline: auto;
    padding-block: 4rem 6rem;
  }
  /* The Contents drawer's clone SOURCE must never paint — `hidden` handles semantics, this pins
     it against any stylesheet that gives `.reader-sidebar` layout outside `.reader-layout`. */
  .pwb-sidebar-src[hidden] {
    display: none !important;
  }
</style>
