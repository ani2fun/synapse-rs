---
// A01's placeholder landing page. Its one job is to prove the WHOLE path — Astro SSR → axum
// API over localhost → rendered HTML through the astro_proxy — before any real porting starts.
// A04 replaces this with the actual library (cards, categories, hero, progress chrome).
import Base from "../layouts/Base.astro";
import { fetchIndex, type CatalogEntry } from "../lib/api/client";

// A01's first draft guessed the wire shape from field presence and silently dropped six of
// seven books. `CatalogEntry` is generated from the server's own OpenAPI document now (step
// A02) — `entries` is a REQUIRED array on `CategoryDto`, not the guessed `entries?`, so the
// `else` branch below no longer needs a defensive presence check to be correct.
let books: { title: string; path: string }[] = [];
let loadError: string | null = null;
try {
  const index = await fetchIndex();
  const walk = (entries: CatalogEntry[], prefix: string[]) => {
    for (const entry of entries) {
      if (entry.kind === "book") {
        books.push({
          title: entry.title,
          path: [...(entry.categoryPath ?? prefix), entry.slug].join("/"),
        });
      } else {
        walk(entry.entries, [...prefix, entry.slug]);
      }
    }
  };
  walk(index.entries, []);
} catch (error) {
  loadError = error instanceof Error ? error.message : String(error);
}
---

<Base title="Synapse">
  <main class="library">
    <h1>Synapse</h1>
    <p class="muted">
      Astro front end — migration step A01. This placeholder proves SSR → API → proxy;
      the real library lands in A04.
    </p>
    {
      loadError ? (
        <p class="error">The catalog failed to load: {loadError}</p>
      ) : (
        <ul>
          {books.map((book) => (
            <li>
              <a href={`/synapse/${book.path}`}>{book.title}</a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Base>
